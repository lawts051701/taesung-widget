<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Taesung" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorAccent">#4F46E5</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:navigationBarColor">#111827</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.Taesung.Dialog" parent="Theme.AppCompat.DayNight.Dialog">
        <item name="colorAccent">#4F46E5</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <style name="WidgetWeekday">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#9A9A9E</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="WidgetWeekdaySunday" parent="WidgetWeekday">
        <item name="android:textColor">#FF6B6B</item>
    </style>

    <style name="WidgetWeekdaySaturday" parent="WidgetWeekday">
        <item name="android:textColor">#6B9BFF</item>
    </style>
</resources>
