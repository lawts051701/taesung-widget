<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="WidgetWeekday">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#9A9A9E</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="WidgetWeekdaySunday" parent="WidgetWeekday">
        <item name="android:textColor">#FF6B6B</item>
    </style>

    <style name="WidgetWeekdaySaturday" parent="WidgetWeekday">
        <item name="android:textColor">#6B9BFF</item>
    </style>
</resources>
