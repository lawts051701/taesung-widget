<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/day_cell_root"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_margin="1dp"
    android:layout_weight="1"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="2dp">

    <TextView
        android:id="@+id/day_num"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:gravity="start|center_vertical"
        android:singleLine="true"
        android:textColor="#E5E5E7"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/day_event_1"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="1dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:singleLine="true"
        android:textColor="#F5F5F5"
        android:textSize="9sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/day_event_2"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="1dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:singleLine="true"
        android:textColor="#F5F5F5"
        android:textSize="9sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/day_event_3"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="1dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:singleLine="true"
        android:textColor="#F5F5F5"
        android:textSize="9sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/day_event_4"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="1dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:singleLine="true"
        android:textColor="#F5F5F5"
        android:textSize="9sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/day_event_5"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="1dp"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:singleLine="true"
        android:textColor="#F5F5F5"
        android:textSize="9sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/day_more"
        android:layout_width="match_parent"
        android:layout_height="11dp"
        android:gravity="center"
        android:singleLine="true"
        android:textColor="#A1A1AA"
        android:textSize="8sp"
        android:visibility="gone" />
</LinearLayout>
